{
  "name": "dealdiligence-backend",
  "version": "1.0.0",
  "description": "DealDiligence.ai Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:test:create": "docker exec dealdiligence-db psql -U postgres -c \"CREATE DATABASE dealdiligence_test;\" || echo Database already exists",
    "db:test:setup": "dotenv -e .env.test -- prisma db push",
    "db:test:reset": "dotenv -e .env.test -- prisma migrate reset --force",
    "db:local:start": "docker run -d --name dealdiligence-db -p 5433:5432 -e POSTGRES_PASSWORD=password -e POSTGRES_DB=dealdiligence -v dealdiligence-pgdata:/var/lib/postgresql/data postgres:16-alpine || docker start dealdiligence-db",
    "db:local:stop": "docker stop dealdiligence-db",
    "db:local:remove": "docker stop dealdiligence-db && docker rm dealdiligence-db && docker volume rm dealdiligence-pgdata",
    "db:seed": "ts-node-dev --transpile-only prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node-dev --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.28.1",
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "diff-match-patch": "^1.0.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "express-oauth2-jwt-bearer": "^1.6.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.0.0",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "uuid": "^9.0.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/diff-match-patch": "^1.0.36",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "dotenv-cli": "^7.4.2",
    "pg": "^8.17.1",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3",
    "vitest": "^4.0.17"
  }
}
