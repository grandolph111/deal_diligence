generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id        String   @id @default(uuid())
  auth0Id   String   @unique
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  memberships      ProjectMember[]
  assignedTasks    TaskAssignee[]
  createdTasks     Task[]          @relation("TaskCreator")
  comments         TaskComment[]   @relation("CommentAuthor")
  assignedSubtasks Subtask[]       @relation("SubtaskAssignee")

  // VDR Relations
  uploadedDocuments Document[]     @relation("DocumentUploader")
  linkedDocuments   TaskDocument[] @relation("TaskDocumentLinker")
  auditLogs         AuditLog[]     @relation("AuditLogUser")
}

// ============================================
// PROJECTS & MEMBERSHIP
// ============================================

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  isArchived  Boolean   @default(false)
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  members            ProjectMember[]
  pendingInvitations PendingInvitation[]
  tasks              Task[]
  documents          Document[]
  tags               Tag[]

  // VDR Relations
  folders   Folder[]
  auditLogs AuditLog[]
}

model ProjectMember {
  id          String      @id @default(uuid())
  projectId   String
  userId      String
  role        ProjectRole @default(VIEWER)
  permissions Json?

  invitedBy  String?
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model PendingInvitation {
  id          String      @id @default(uuid())
  projectId   String
  email       String
  role        ProjectRole @default(VIEWER)
  permissions Json?

  token       String   @unique @default(uuid())
  invitedBy   String
  invitedAt   DateTime @default(now())
  expiresAt   DateTime
  acceptedAt  DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
  @@index([email])
  @@index([token])
}

// ============================================
// KANBAN TASKS
// ============================================

model Task {
  id           String       @id @default(uuid())
  projectId    String
  title        String
  description  String?
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  riskCategory String?

  assignedDate DateTime?
  dueDate      DateTime?
  timeEstimate Int?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy     User             @relation("TaskCreator", fields: [createdById], references: [id])
  assignees     TaskAssignee[]
  tags          TaskTag[]
  attachments   TaskAttachment[]
  comments      TaskComment[]
  subtasks      Subtask[]
  taskDocuments TaskDocument[]

  @@index([projectId])
  @@index([projectId, status])
  @@index([createdById])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  COMPLETE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SubtaskStatus {
  TODO
  IN_PROGRESS
  COMPLETE
}

model TaskAssignee {
  id         String   @id @default(uuid())
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

model Tag {
  id        String @id @default(uuid())
  projectId String
  name      String
  color     String @default("#6B7280")

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   TaskTag[]

  @@unique([projectId, name])
  @@index([projectId])
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("CommentAuthor", fields: [authorId], references: [id])

  @@index([taskId])
  @@index([taskId, createdAt])
}

model Subtask {
  id          String        @id @default(uuid())
  taskId      String
  title       String
  description String?
  status      SubtaskStatus @default(TODO)
  assigneeId  String?
  dueDate     DateTime?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  task     Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee User? @relation("SubtaskAssignee", fields: [assigneeId], references: [id])

  @@index([taskId])
  @@index([taskId, order])
}

model TaskAttachment {
  id         String @id @default(uuid())
  taskId     String
  documentId String

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([taskId, documentId])
}

// ============================================
// VIRTUAL DATA ROOM (Phase 2)
// ============================================

model Folder {
  id        String  @id @default(uuid())
  projectId String
  name      String
  parentId  String?

  // Standard DD category marker
  categoryType String?

  // Access control
  isViewOnly Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    Folder?    @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]   @relation("FolderHierarchy")
  documents Document[]

  @@unique([projectId, parentId, name])
  @@index([projectId])
  @@index([parentId])
}

model Document {
  id        String @id @default(uuid())
  projectId String
  folderId  String?

  // File info
  name      String
  s3Key     String @unique
  mimeType  String
  sizeBytes Int

  // BerryDB integration
  berryDbId        String?        @unique
  processingStatus DocumentStatus @default(PENDING)

  // Extracted metadata (synced from BerryDB)
  documentType  String?
  riskLevel     String?
  pageCount     Int?
  extractedText String? @db.Text
  language      String?
  currency      String?
  region        String?

  // Access control
  isViewOnly Boolean @default(false)

  // Audit
  uploadedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder          Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedBy      User             @relation("DocumentUploader", fields: [uploadedById], references: [id])
  taskAttachments TaskAttachment[]
  chunks          DocumentChunk[]
  taskDocuments   TaskDocument[]

  @@index([projectId])
  @@index([projectId, folderId])
  @@index([projectId, documentType])
  @@index([projectId, processingStatus])
}

enum DocumentStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

model DocumentChunk {
  id         String @id @default(uuid())
  documentId String
  chunkIndex Int
  content    String @db.Text
  pageNumber Int?
  tokenCount Int?
  // embedding  Unsupported("vector(1536)")  // Uncomment for pgvector

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, chunkIndex])
}

// ============================================
// TASK-DOCUMENT LINKING
// ============================================

model TaskDocument {
  id         String @id @default(uuid())
  taskId     String
  documentId String

  // Audit
  linkedById String
  linkedAt   DateTime @default(now())

  // Relations
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  linkedBy User     @relation("TaskDocumentLinker", fields: [linkedById], references: [id])

  @@unique([taskId, documentId])
  @@index([taskId])
  @@index([documentId])
}

// ============================================
// AUDIT LOGGING
// ============================================

model AuditLog {
  id         String @id @default(uuid())
  projectId  String
  userId     String

  action       String // upload, download, view, search, chat, delete, etc.
  resourceType String // document, folder, chat, project, etc.
  resourceId   String?

  metadata  Json?   // Additional context (search query, etc.)
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("AuditLogUser", fields: [userId], references: [id])

  @@index([projectId])
  @@index([projectId, createdAt])
  @@index([projectId, action])
  @@index([userId])
}
