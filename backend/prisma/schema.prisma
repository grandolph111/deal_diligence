generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id        String   @id @default(uuid())
  auth0Id   String   @unique
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  memberships      ProjectMember[]
  assignedTasks    TaskAssignee[]
  createdTasks     Task[]          @relation("TaskCreator")
  createdBoards    KanbanBoard[]   @relation("BoardCreator")
  comments         TaskComment[]   @relation("CommentAuthor")
  assignedSubtasks Subtask[]       @relation("SubtaskAssignee")

  // VDR Relations
  uploadedDocuments Document[]     @relation("DocumentUploader")
  linkedDocuments   TaskDocument[] @relation("TaskDocumentLinker")
  auditLogs         AuditLog[]     @relation("AuditLogUser")

  // Phase 2B Relations
  verifiedAnnotations DocumentAnnotation[] @relation("AnnotationVerifier")
  rejectedAnnotations DocumentAnnotation[] @relation("AnnotationRejecter")

  // Phase 3 Relations (AI Chat)
  chatConversations ChatConversation[] @relation("ConversationCreator")
}

// ============================================
// PROJECTS & MEMBERSHIP
// ============================================

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?
  isArchived  Boolean   @default(false)
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Playbook (standard positions + red flags) conditioning extraction risk.
  playbook Json?

  // Deal brief scope manifest: { [scopeKey]: { s3Key, updatedAt } }
  briefManifest Json?

  // Relations
  members            ProjectMember[]
  pendingInvitations PendingInvitation[]
  tasks              Task[]
  boards             KanbanBoard[]
  documents          Document[]
  tags               Tag[]

  // VDR Relations
  folders   Folder[]
  auditLogs AuditLog[]

  // Phase 2B Relations
  masterEntities MasterEntity[]

  // Phase 3 Relations (AI Chat)
  chatConversations ChatConversation[]
}

model ProjectMember {
  id          String      @id @default(uuid())
  projectId   String
  userId      String
  role        ProjectRole @default(VIEWER)
  permissions Json?

  invitedBy  String?
  invitedAt  DateTime  @default(now())
  acceptedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model PendingInvitation {
  id          String      @id @default(uuid())
  projectId   String
  email       String
  role        ProjectRole @default(VIEWER)
  permissions Json?

  token       String   @unique @default(uuid())
  invitedBy   String
  invitedAt   DateTime @default(now())
  expiresAt   DateTime
  acceptedAt  DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
  @@index([email])
  @@index([token])
}

// ============================================
// KANBAN TASKS (multi-board)
// ============================================

model KanbanBoard {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  description String?
  // Default board = auto-migrated "All Documents" board. Cannot be deleted.
  isDefault   Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User                @relation("BoardCreator", fields: [createdById], references: [id])
  folders   KanbanBoardFolder[]
  tasks     Task[]

  @@unique([projectId, name])
  @@index([projectId])
}

// N:N join: which data-room folders a board covers.
model KanbanBoardFolder {
  boardId  String
  folderId String

  board  KanbanBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  folder Folder      @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@id([boardId, folderId])
  @@index([boardId])
  @@index([folderId])
}

model Task {
  id           String       @id @default(uuid())
  projectId    String
  // Nullable during migration window — tightened to NOT NULL after backfill.
  boardId      String?
  title        String
  description  String?
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  riskCategory String?

  assignedDate DateTime?
  dueDate      DateTime?
  timeEstimate Int?

  // AI workflow fields (null = plain task; non-null = AI task)
  aiPrompt           String?       @db.Text
  aiStatus           TaskAiStatus?
  aiReportS3Key      String?
  aiReportSummary    String?       @db.Text
  aiModel            String?
  aiConfidenceScore  Int?
  aiConfidenceReason String?       @db.Text
  aiStartedAt        DateTime?
  aiCompletedAt      DateTime?
  aiError            String?       @db.Text

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  board         KanbanBoard?     @relation(fields: [boardId], references: [id], onDelete: SetNull)
  createdBy     User             @relation("TaskCreator", fields: [createdById], references: [id])
  assignees     TaskAssignee[]
  tags          TaskTag[]
  attachments   TaskAttachment[]
  comments      TaskComment[]
  subtasks      Subtask[]
  taskDocuments TaskDocument[]

  @@index([projectId])
  @@index([boardId])
  @@index([boardId, status])
  @@index([projectId, status])
  @@index([projectId, aiStatus])
  @@index([createdById])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  COMPLETE
}

enum TaskAiStatus {
  IDLE
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SubtaskStatus {
  TODO
  IN_PROGRESS
  COMPLETE
}

model TaskAssignee {
  id         String   @id @default(uuid())
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

model Tag {
  id        String @id @default(uuid())
  projectId String
  name      String
  color     String @default("#6B7280")

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   TaskTag[]

  @@unique([projectId, name])
  @@index([projectId])
}

model TaskTag {
  taskId String
  tagId  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation("CommentAuthor", fields: [authorId], references: [id])

  @@index([taskId])
  @@index([taskId, createdAt])
}

model Subtask {
  id          String        @id @default(uuid())
  taskId      String
  title       String
  description String?
  status      SubtaskStatus @default(TODO)
  assigneeId  String?
  dueDate     DateTime?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  task     Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee User? @relation("SubtaskAssignee", fields: [assigneeId], references: [id])

  @@index([taskId])
  @@index([taskId, order])
}

model TaskAttachment {
  id         String @id @default(uuid())
  taskId     String
  documentId String

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([taskId, documentId])
}

// ============================================
// VIRTUAL DATA ROOM (Phase 2)
// ============================================

model Folder {
  id        String  @id @default(uuid())
  projectId String
  name      String
  parentId  String?

  // Standard DD category marker
  categoryType String?

  // Access control
  isViewOnly Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent       Folder?             @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children     Folder[]            @relation("FolderHierarchy")
  documents    Document[]
  kanbanBoards KanbanBoardFolder[]

  @@unique([projectId, parentId, name])
  @@index([projectId])
  @@index([parentId])
}

model Document {
  id        String @id @default(uuid())
  projectId String
  folderId  String?

  // File info
  name      String
  s3Key     String @unique
  mimeType  String
  sizeBytes Int

  // Processing pipeline
  processingStatus DocumentStatus @default(PENDING)
  retryCount       Int?           @default(0)
  lastError        String?

  // Claude extraction output
  extractionS3Key       String? // S3 pointer to fact-sheet markdown
  extractionSummary     String? @db.Text // first ~200 chars for list views
  extractionContentHash String? // S3 ETag + model ID composite; idempotency key
  extractionModel       String? // audit

  // Risk assessment (produced by first-pass extraction)
  riskScore   Int? // 0-10 scale
  riskLevel   String? // LOW | MEDIUM | HIGH (derived from riskScore)
  riskSummary String? @db.Text // prose top-3-risks summary

  // Deal metadata (produced by first-pass extraction)
  documentType           String?
  documentTypeConfidence Float?
  pageCount              Int?
  extractedText          String? @db.Text
  language               String?
  currency               String?
  region                 String?
  dealValue              Decimal?
  effectiveDate          DateTime?
  governingLaw           String?

  // Self-reported confidence in extraction quality (0-100)
  confidenceScore  Int?
  confidenceReason String? @db.Text

  // Verification pass (Sonnet, two-pass quality gate)
  verificationStatus String? // VERIFIED | NEEDS_REVIEW | FAILED | null
  verificationIssues Json? // array of {type, severity, description, location, suggestedCorrection}

  // Peer-group anomaly flags from reconciliation
  anomalyFlags Json? // array of {clauseType, thisValue, peerValue, peerSize, reason}

  // Access control
  isViewOnly Boolean @default(false)

  // Audit
  uploadedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder          Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedBy      User             @relation("DocumentUploader", fields: [uploadedById], references: [id])
  taskAttachments TaskAttachment[]
  taskDocuments   TaskDocument[]

  // Phase 2B Relations
  entities    DocumentEntity[]
  annotations DocumentAnnotation[]

  @@index([projectId])
  @@index([projectId, folderId])
  @@index([projectId, documentType])
  @@index([projectId, processingStatus])
  @@index([projectId, riskScore])
}

enum DocumentStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

// ============================================
// TASK-DOCUMENT LINKING
// ============================================

model TaskDocument {
  id         String @id @default(uuid())
  taskId     String
  documentId String

  // Audit
  linkedById String
  linkedAt   DateTime @default(now())

  // Relations
  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  linkedBy User     @relation("TaskDocumentLinker", fields: [linkedById], references: [id])

  @@unique([taskId, documentId])
  @@index([taskId])
  @@index([documentId])
}

// ============================================
// INTELLIGENT EXTRACTION (Phase 2B)
// ============================================

// Entities extracted from documents (companies, people, amounts, dates, etc.)
model DocumentEntity {
  id         String @id @default(uuid())
  documentId String

  // Entity details
  entityType     String  // COMPANY, PERSON, AMOUNT, DATE, CLAUSE, JURISDICTION, etc.
  text           String  // Original text as it appears in the document
  normalizedText String? // Cleaned/normalized version of the text

  // Position in document
  pageNumber  Int?
  startOffset Int? // Character offset in extracted text
  endOffset   Int?

  // Confidence and source
  confidence Float   @default(1.0) // 0.0 to 1.0
  source     String? // BerryDB, manual, etc.

  // Low confidence flag for human review
  needsReview Boolean @default(false)

  // Link to canonical entity
  masterEntityId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  document     Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  masterEntity MasterEntity? @relation(fields: [masterEntityId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([documentId, entityType])
  @@index([masterEntityId])
  @@index([entityType])
  @@index([needsReview])
}

// Canonical/deduplicated entities across all documents in a project
model MasterEntity {
  id        String @id @default(uuid())
  projectId String

  // Entity details
  entityType     String // COMPANY, PERSON, etc.
  canonicalName  String // The primary/canonical name
  aliases        Json?  // Array of alternative names/spellings

  // Additional metadata
  metadata Json? // Type-specific data (e.g., company registration, person role)

  // Knowledge graph relationships
  relatedEntities EntityRelationship[] @relation("SourceEntity")
  relatedFrom     EntityRelationship[] @relation("TargetEntity")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentEntities DocumentEntity[]

  @@unique([projectId, entityType, canonicalName])
  @@index([projectId])
  @@index([projectId, entityType])
}

// Relationships between entities for knowledge graph
model EntityRelationship {
  id             String @id @default(uuid())
  sourceEntityId String
  targetEntityId String
  relationshipType String // PARTY_TO, REFERENCES, EMPLOYS, OWNS, etc.

  // Evidence
  documentId String? // Document where relationship was found
  confidence Float   @default(1.0)
  metadata   Json?   // Additional context about the relationship

  createdAt DateTime @default(now())

  // Relations
  sourceEntity MasterEntity @relation("SourceEntity", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  targetEntity MasterEntity @relation("TargetEntity", fields: [targetEntityId], references: [id], onDelete: Cascade)

  @@unique([sourceEntityId, targetEntityId, relationshipType])
  @@index([sourceEntityId])
  @@index([targetEntityId])
  @@index([relationshipType])
}

// Annotations on documents (clauses, risk flags, manual notes)
model DocumentAnnotation {
  id         String @id @default(uuid())
  documentId String

  // Annotation type
  annotationType String // CLAUSE, RISK_FLAG, NOTE, VERIFICATION, etc.

  // Content
  title       String?
  content     String  @db.Text // The annotated text or note content
  clauseType  String? // For CLAUSE type: INDEMNIFICATION, TERMINATION, LIABILITY, etc.
  riskLevel   String? // For RISK_FLAG type: LOW, MEDIUM, HIGH

  // Position in document
  pageNumber  Int?
  startOffset Int?
  endOffset   Int?

  // Source
  source     String? // AI, manual, etc.
  confidence Float?  @default(1.0)

  // Human verification
  isVerified       Boolean   @default(false)
  verifiedById     String?
  verifiedAt       DateTime?
  verificationNote String?

  // Rejection (for incorrect AI annotations)
  isRejected     Boolean @default(false)
  rejectedById   String?
  rejectedAt     DateTime?
  rejectionNote  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  verifiedBy User?    @relation("AnnotationVerifier", fields: [verifiedById], references: [id])
  rejectedBy User?    @relation("AnnotationRejecter", fields: [rejectedById], references: [id])

  @@index([documentId])
  @@index([documentId, annotationType])
  @@index([annotationType])
  @@index([clauseType])
  @@index([riskLevel])
  @@index([isVerified])
  @@index([isRejected])
}

// ============================================
// AI CHAT (Phase 3)
// ============================================

model ChatConversation {
  id        String @id @default(uuid())
  projectId String

  // Conversation details
  title     String?  // Auto-generated or user-set title
  createdById String

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User          @relation("ConversationCreator", fields: [createdById], references: [id])
  messages  ChatMessage[]

  @@index([projectId])
  @@index([projectId, createdAt])
  @@index([createdById])
}

model ChatMessage {
  id             String @id @default(uuid())
  conversationId String

  // Message content
  role    ChatMessageRole // USER, ASSISTANT, SYSTEM
  content String          @db.Text

  // For assistant messages: citations to source documents
  citations Json? // Array of { documentId, pageNumber, snippet }

  // Timestamps
  createdAt DateTime @default(now())

  // Relations
  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ============================================
// AUDIT LOGGING
// ============================================

model AuditLog {
  id         String @id @default(uuid())
  projectId  String
  userId     String

  action       String // upload, download, view, search, chat, delete, etc.
  resourceType String // document, folder, chat, project, etc.
  resourceId   String?

  metadata  Json?   // Additional context (search query, etc.)
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("AuditLogUser", fields: [userId], references: [id])

  @@index([projectId])
  @@index([projectId, createdAt])
  @@index([projectId, action])
  @@index([userId])
}
